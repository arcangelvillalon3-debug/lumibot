# ══════════════════════════════════
#  LumiBot — Variables de Entorno
#  Copia este archivo como .env
#  NUNCA subas .env a GitHub
# ══════════════════════════════════

# Puerto del servidor
PORT=3000

# API Key de Anthropic (para el tutor IA)
# Consíguela en: https://console.anthropic.com
ANTHROPIC_API_KEY=tu_api_key_aqui

# Supabase (base de datos — opcional en dev)
# Créala gratis en: https://supabase.com
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui

# Stripe (pagos — opcional en dev)
# Consíguela en: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_tu_key_aqui
STRIPE_PRICE_ID=price_tu_price_id_aqui

# URL de producción
APP_URL=https://lumibot.app
